global.cutscene = true; 
caractere_atual = 0;    

// --- ROTEIRO DA MISSÃO ---
fala[1] = "Agente Zero... há três horas um portal dimensional foi aberto.";
quem[1] = "GENERAL";

fala[2] = "Do outro lado existe uma versão distorcida da nossa realidade. Um mundo paralelo.";
quem[2] = "GENERAL";

fala[3] = "Este prédio não pertence mais à nossa dimensão. Ele foi puxado para lá e voltou contaminado.";
quem[3] = "GENERAL";

fala[4] = "Infectados?";
quem[4] = "AGENTE ZERO";

fala[5] = "Todos. Cientistas, segurança... ninguém sobrou. O laboratório no subsolo é a origem.";
quem[5] = "GENERAL";

fala[6] = "Sua missão é simples... e suicida.\nLimpar o prédio. Destruir o laboratório. E fugir.";
quem[6] = "GENERAL";

fala[7] = "Regras de combate?";
quem[7] = "AGENTE ZERO";

fala[8] = "[A], [D] para se mover. [I] para faca (silencioso). [K] para abrir fogo quando o silêncio não for opção. \n [U] para usar o kit médico. Você vai precisar. [L] para lanterna. A outra dimensão é escura. [E] para interagir.";
quem[8] = "GENERAL";

fala[9] = "E se o portal fechar?";
quem[9] = "AGENTE ZERO";

fala[10] = "Então você vira parte daquele mundo...";
quem[10] = "GENERAL";

fala[11] = "Hora de limpar outra dimensão.";
quem[11] = "AGENTE ZERO";

fala[12] = "Boa sorte, Zero. E lembre-se... Não confie na escuridão. Lá, ela respira.";
quem[12] = "GENERAL";

fala[12] = "Boa sorte, Zero. E lembre-se... Não confie na escuridão. Lá, ela respira.";
quem[12] = "GENERAL";

// --- NOVA FALA ADICIONADA ---
fala[13] = "E um último aviso: use sua lanterna nas paredes. \nAlgumas anomalias e suprimentos só se revelam sob a luz direta.";
quem[13] = "GENERAL";

total_passos = 13; // <-- ATUALIZADO PARA 13
passo = 1;
texto_exibir = fala[1];
nome_exibir = quem[1];